{
  "name": "z-build-order",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy",
    "preview-deploy": "npm run clean-dist && npm run build && firebase hosting:channel:deploy dev",
    "clean-dist": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('node_modules/.vite', { recursive: true, force: true }); fs.rmSync('dist', { recursive: true, force: true });\"",
    "minify-firebase": "node scripts/minify-firebase.js",
    "cleanup-covers": "cd functions && node scripts/cleanupTournamentCovers.js",
    "cleanup-covers:apply": "cd functions && node scripts/cleanupTournamentCovers.js --apply",
    "bracket-sim": "node scripts/bracket-sim.js",
    "test:ui": "playwright test",
    "test:load": "node functions/scripts/tournamentLoadHarness.js",
    "test:load:emulator": "firebase emulators:exec --only firestore \"node functions/scripts/tournamentLoadHarness.js --projectId demo-z-build-order $LOAD_ARGS\""
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "firebase-tools": "^15.8.0",
    "rimraf": "^6.0.1",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "dompurify": "^3.2.5",
    "firebase": "^12.7.0"
  }
}
