rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSafeImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }
  
    // ✅ Allow uploading clan logos
    match /clanLogos/{clanId}/{fileName} {
      allow read: if true;
      
      allow write: if request.auth != null
        && (request.resource == null || isSafeImageUpload(12 * 1024 * 1024))
        && (
        firestore.get(
          /databases/(default)/documents/clans/$(clanId)
        ).data.adminUid == request.auth.uid ||
        
        firestore.get(
          /databases/(default)/documents/clans/$(clanId)
        ).data.memberInfo[request.auth.uid].role == "Captain" ||
        
        firestore.get(
          /databases/(default)/documents/clans/$(clanId)
        ).data.memberInfo[request.auth.uid].role == "Co-Captain"
      );
    }

    // ✅ Allow uploading tournament cover images
    match /tournamentCovers/{slug}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.resource == null || isSafeImageUpload(12 * 1024 * 1024))
        && (
        firestore.get(
          /databases/(default)/documents/tournaments/$(slug)
        ).data.createdBy == request.auth.uid ||
        (
          firestore.get(
            /databases/(default)/documents/tournaments/$(slug)
          ).data.adminUids is list &&
          request.auth.uid in firestore.get(
            /databases/(default)/documents/tournaments/$(slug)
          ).data.adminUids
        ) ||
        firestore.get(
          /databases/(default)/documents/tournamentCircuits/$(
            firestore.get(/databases/(default)/documents/tournaments/$(slug)).data.circuitSlug
          )
        ).data.createdBy == request.auth.uid
      );
    }

    // ? Allow uploading tournament sponsor logos
    match /tournamentSponsors/{slug}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.resource == null || isSafeImageUpload(12 * 1024 * 1024))
        && (
        firestore.get(
          /databases/(default)/documents/tournaments/$(slug)
        ).data.createdBy == request.auth.uid ||
        (
          firestore.get(
            /databases/(default)/documents/tournaments/$(slug)
          ).data.adminUids is list &&
          request.auth.uid in firestore.get(
            /databases/(default)/documents/tournaments/$(slug)
          ).data.adminUids
        ) ||
        firestore.get(
          /databases/(default)/documents/tournamentCircuits/$(
            firestore.get(/databases/(default)/documents/tournaments/$(slug)).data.circuitSlug
          )
        ).data.createdBy == request.auth.uid
      );
    }

    // ✅ Allow uploading custom tournament map images
    match /tournamentMaps/{slug}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.resource == null || isSafeImageUpload(12 * 1024 * 1024))
        && (
        firestore.get(
          /databases/(default)/documents/tournaments/$(slug)
        ).data.createdBy == request.auth.uid ||
        (
          firestore.get(
            /databases/(default)/documents/tournaments/$(slug)
          ).data.adminUids is list &&
          request.auth.uid in firestore.get(
            /databases/(default)/documents/tournaments/$(slug)
          ).data.adminUids
        ) ||
        firestore.get(
          /databases/(default)/documents/tournamentCircuits/$(
            firestore.get(/databases/(default)/documents/tournaments/$(slug)).data.circuitSlug
          )
        ).data.createdBy == request.auth.uid
      );
    }

    // ❌ Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
